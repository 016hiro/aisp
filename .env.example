# ── OpenRouter API（必填）──
AISP_OPENROUTER__API_KEY=sk-or-v1-xxxx
AISP_OPENROUTER__ANALYSIS_MODEL=anthropic/claude-sonnet-4
AISP_OPENROUTER__SENTIMENT_MODEL=google/gemini-2.0-flash-001

# ── Database（可选，默认 data/aisp.db）──
AISP_DB__URL=sqlite+aiosqlite:///data/aisp.db

# ── 8 因子评分权重（可选，须加和为 1.0）──
AISP_SCORING__WEIGHT_FUND=0.20
AISP_SCORING__WEIGHT_MOMENTUM=0.10
AISP_SCORING__WEIGHT_TECHNICAL=0.10
AISP_SCORING__WEIGHT_QUALITY=0.05
AISP_SCORING__WEIGHT_INDICATORS=0.20
AISP_SCORING__WEIGHT_MACRO=0.10
AISP_SCORING__WEIGHT_SENTIMENT=0.15
AISP_SCORING__WEIGHT_SECTOR=0.10

# ── 弹性权重（可选）──
AISP_SCORING__ELASTICITY=2.0
AISP_SCORING__INDICATOR_LOOKBACK_DAYS=70

# ── 否决规则阈值（可选）──
AISP_VETO__MACRO_FLOOR=0.15
AISP_VETO__SENTIMENT_FLOOR=0.10
AISP_VETO__SENTIMENT_CEILING=0.95

# ── 板块池配置（可选）──
# AISP_POOL__CORE_SECTORS='["半导体","汽车整车","光伏设备","白酒","银行"]'
# AISP_POOL__MOMENTUM_TOP_N=10
# AISP_POOL__MOMENTUM_EXIT_DAYS=5
# AISP_POOL__OPPORTUNITY_TOP_N=10
# AISP_POOL__OPPORTUNITY_OBSERVE_DAYS=3
# AISP_POOL__TOP_STOCKS_PER_SECTOR=5

# ── 威科夫校准层（可选）──
# AISP_WYCKOFF__ENABLED=true
# AISP_WYCKOFF__MIN_BARS=60
# AISP_WYCKOFF__ACC_MAX_MULTIPLIER=1.25
# AISP_WYCKOFF__DIST_MIN_MULTIPLIER=0.60

# ── 突破信号检测层（可选）──
# AISP_BREAKOUT__ENABLED=true
# AISP_BREAKOUT__STRONG_THRESHOLD=0.60
# AISP_BREAKOUT__WEAK_THRESHOLD=0.35
# AISP_BREAKOUT__VOL_CONFIRM_RATIO=1.5

# ── 交易计划生成层（可选）──
# AISP_TRADING_PLAN__ENABLED=true
# AISP_TRADING_PLAN__ATR_PERIOD=20
# AISP_TRADING_PLAN__STOP_BUFFER_PCT=0.01

# ── OCR 持仓/交割单识别（可选）──
# AISP_OCR__MODEL=google/gemini-3.1-flash-lite-preview
# AISP_OCR__CONFIDENCE_THRESHOLD=0.7
# AISP_OCR__MAX_IMAGE_SIZE_MB=10

# ── Telegram Bot（可选，启用 aisp telegram 命令需填写）──
# AISP_TELEGRAM__BOT_TOKEN=123456:ABC-DEF...
# AISP_TELEGRAM__ALLOWED_USER_IDS=[123456789]

# ── 搜索代理（可选，DuckDuckGo 搜索走代理）──
# AISP_SEARCH_PROXY=socks5://127.0.0.1:1080

# ── 简报输出目录（可选）──
# AISP_BRIEFING_DIR=briefings
